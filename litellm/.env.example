# Governance enforcement layer — environment template.
# Copy to .env and fill in. NEVER commit the real .env. The proxy reads these at startup.

# --- Upstream model provider (required) ---
# The single secret that must never be handed to clients. Its non-exposure is what makes
# the LiteLLM proxy an unbypassable chokepoint.
ANTHROPIC_API_KEY=

# --- Proxy admin (required) ---
# Master key for the LiteLLM proxy's own admin/auth surface. Generate a long random value.
LITELLM_MASTER_KEY=

# --- Redis (required for the override state machine across requests/replicas) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# --- Governance toggles (optional; defaults shown) ---
# Path to the injected governance core. Defaults to litellm/governance_core.md.
GOVERNANCE_CORE_PATH=/app/governance_core.md

# Force non-streaming so responses are buffered and the output guard can hard-block.
# Strongly recommended ON; turning this off makes output rules audit-only.
GOV_FORCE_NON_STREAMING=true

# Hard-block secret-bearing input / output.
GOV_BLOCK_SECRETS_INPUT=true
GOV_BLOCK_SECRETS_OUTPUT=true

# Two-key Override Protocol state machine (deterministic; cannot be self-granted).
GOV_ENABLE_OVERRIDE=true
GOV_OVERRIDE_PENDING_TTL=1800     # seconds a pending override request stays valid (KEY 1)
GOV_OVERRIDE_UNLOCKED_TTL=120     # seconds an unlocked override stays valid (KEY 2), single turn

# Semantic verifier (LLM-as-judge for scope/intent). OFF by default: adds latency + cost,
# and only *reduces* violations — it never guarantees them. Fails open on error.
GOV_ENABLE_VERIFIER=false
GOV_VERIFIER_MODEL=claude-haiku

# --- Open WebUI (optional reinforcement UI) ---
WEBUI_SECRET_KEY=changeme
